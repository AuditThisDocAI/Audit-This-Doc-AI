{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user account registration with payment credentials and billing credit limits.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID from Firebase Authentication."
        },
        "email": {
          "type": "string",
          "description": "Verified user email address."
        },
        "paymentTier": {
          "type": "string",
          "enum": ["free", "unlimited", "bundle", "payg"],
          "description": "Subscription payment tier: unlimited ($65/year for unlimited usage of apps/documents generator), credit bundle ($10 for 20 invoices), pay-as-you-go ($0.50 per invoice), or free tier."
        },
        "invoiceCredits": {
          "type": "integer",
          "description": "Remaining invoice creation credits for bundle or pay-as-you-go tiers."
        },
        "amountPaid": {
          "type": "number",
          "description": "Cumulative USD payment amount paid by the user."
        },
        "invoicesCount": {
          "type": "integer",
          "description": "Total number of documents generated by this user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Registration audit timestamp."
        }
      },
      "required": ["uid", "email", "paymentTier"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Audit record containing complete transaction items list and legal terms.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Autogenerated file tracking register ID."
        },
        "userId": {
          "type": "string",
          "description": "Submitting user account UID references."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Time the document was saved in database."
        },
        "documentNumber": {
          "type": "string",
          "description": "User visible custom tracking identifier."
        },
        "documentType": {
          "type": "string",
          "enum": ["invoice", "receipt", "quote", "purchase_order", "delivery_note", "custom", "letterhead", "resume"],
          "description": "Document category category designator."
        },
        "customTypeName": {
          "type": "string"
        },
        "issueDate": {
          "type": "string"
        },
        "dueDate": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "senderCompany": {
          "type": "string"
        },
        "senderName": {
          "type": "string"
        },
        "clientCompany": {
          "type": "string"
        },
        "clientName": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "terms": {
          "type": "string"
        },
        "itemsJson": {
          "type": "string",
          "description": "Serialized line items grid to stay compliant with Firestore rules constraints."
        }
      },
      "required": ["id", "userId", "documentNumber", "documentType"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Core users list record."
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Individual invoices stored inside a user's isolated subcollection."
    }
  }
}
